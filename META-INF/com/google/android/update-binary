#!/system/bin/sh
# Minimal installer for recovery-style module zips.

MODPATH=$2
TARGET_DIR="/data/adb/modules/wifi_roaming_enhancer"

ui_print() {
    echo "$1"
}

run_program() {
    "$@"
}

ui_print "Installing WiFi Roaming Enhancer Ultimate..."
mkdir -p "$TARGET_DIR"

if [ -x /system/bin/busybox ]; then
    run_program /system/bin/busybox cp -af "$MODPATH"/* "$TARGET_DIR"/
else
    cp -af "$MODPATH"/* "$TARGET_DIR"/
fi

chmod 755 "$TARGET_DIR/service.sh" "$TARGET_DIR/post-fs-data.sh" 2>/dev/null
chmod 755 "$TARGET_DIR/webroot/action.sh" 2>/dev/null

ui_print "Installation complete!"
exit 0
